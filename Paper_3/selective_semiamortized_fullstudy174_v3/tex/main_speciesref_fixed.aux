\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces PCA displacement analysis. Left: oracle $\to $ ensemble. Center: oracle $\to $ refined (medium budget). Right: ensemble predictions colored by uncertainty. Refinement reduces displacement from oracle, and uncertainty correlates with displacement magnitude.}}{22}{figure.11}}
\newlabel{fig:displacement}{{11}{22}{PCA displacement analysis. Left: oracle $\to $ ensemble. Center: oracle $\to $ refined (medium budget). Right: ensemble predictions colored by uncertainty. Refinement reduces displacement from oracle, and uncertainty correlates with displacement magnitude}{figure.11}{}}
